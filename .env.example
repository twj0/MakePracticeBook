# 环境变量配置文件
# OpenAI 兼容公益接口（默认主力）
# 文档中已适配 OpenAI 兼容格式
OPENAI_API_BASE=https://api.astrdark.cyou
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=longcat-flash-lite

# 备选模型：
# longcat-flash-thinking-2601
# longcat-flash-thinking
# longcat-flash-chat
# longcat-flash-lite

# Groq API
# 申请链接 https://console.groq.com
# 推荐使用多个 key 轮换，使用分号分隔
GROQ_API_KEYS=your_groq_api_key_here;your_backup_key_here

# 智谱 API
# 申请链接 https://bigmodel.cn/usercenter/proj-mgmt/apikeys
ZHIPUAI_API_KEY=your_api_key_here

# 系统代理（可选）
# 如果你的网络需要代理访问接口，请设置以下任意一个：
# HTTPS_PROXY=https://127.0.0.1:10808
# HTTP_PROXY=http://127.0.0.1:10808
# ALL_PROXY=socks5://127.0.0.1:10808
HTTP_PROXY=http://127.0.0.1:10808
